{
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/pages/landing-page/index.html"
    },
    {
      "source": "/landing-page.css",
      "destination": "/frontend/pages/landing-page/landing-page.css"
    },
    {
      "source": "/images/(.*)",
      "destination": "/frontend/images/$1"
    }
  ]
}
